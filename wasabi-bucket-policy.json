{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "EnforceTLSRequestsOnly",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::kia-recordings",
        "arn:aws:s3:::kia-recordings/*"
      ],
      "Condition": {
        "Bool": {
          "aws:SecureTransport": "false"
        }
      }
    },
    {
      "Sid": "DenyPublicReadAcl",
      "Effect": "Deny",
      "Principal": "*",
      "Action": [
        "s3:PutObjectAcl",
        "s3:PutBucketAcl"
      ],
      "Resource": [
        "arn:aws:s3:::kia-recordings",
        "arn:aws:s3:::kia-recordings/*"
      ],
      "Condition": {
        "StringEquals": {
          "s3:x-amz-acl": [
            "public-read",
            "public-read-write",
            "authenticated-read"
          ]
        }
      }
    }
  ]
}
